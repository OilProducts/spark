            "kind": {
              "enum": [
                "tool"
              ],
              "type": "string"
            },
            "output_map": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
