        {
          "properties": {
            "decisions": {
              "items": {
                "$ref": "#/definitions/HumanDecision"
              },
              "type": "array"
            },
            "details_from": {
              "description": "Context keys whose values are presented alongside the question so the reviewer sees what they are approving.",
