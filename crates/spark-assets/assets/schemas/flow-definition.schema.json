          ]
        },
        "llm_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "llm_provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "reasoning_effort": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
