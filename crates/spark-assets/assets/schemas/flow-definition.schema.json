        "execution": {
          "anyOf": [
            {
              "$ref": "#/definitions/ExecutionConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "extensions": {
          "additionalProperties": true,
          "type": "object"
        },
        "kind": {
          "$ref": "#/definitions/NodeKind"
        },
        "label": {
          "default": "",
          "type": "string"
