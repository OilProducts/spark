          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "exit"
              ],
              "type": "string"
            },
            "result_summary": {
              "description": "When true, reaching this exit produces the run result by pointing a summarizer agent at the run's recorded transcripts and artifacts. Failed runs use any opted-in exit.",
