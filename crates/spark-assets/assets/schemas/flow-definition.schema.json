            "prompt": {
              "default": "",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "conditional"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "join_k": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "join_policy": {
              "type": [
                "string",
                "null"
              ]
            },
            "join_quorum": {
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "parallel"
              ],
              "type": "string"
            },
            "max_parallel": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "fan_in"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "command": {
              "default": "",
              "type": "string"
