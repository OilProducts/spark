        "class": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_policy": {
          "type": [
            "string",
            "null"
          ]
        },
        "fallback_retry_target": {
          "type": [
            "string",
            "null"
          ]
        },
        "fidelity": {
          "type": [
            "string",
            "null"
          ]
        },
        "goal_gate": {
          "type": "boolean"
        },
        "retry_target": {
          "type": [
            "string",
            "null"
          ]
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "RetryConfig": {
      "properties": {
        "max_retries": {
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "policy": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "UiConfig": {
      "properties": {
        "x": {
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "y": {
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        }
      },
      "type": "object"
    }
