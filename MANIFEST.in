include Cargo.toml
include Cargo.lock
include Dockerfile
include Dockerfile.wheel
include compose.package.yaml
include justfile
include scripts/build_deliverable.py
include scripts/package-entrypoint.sh
include scripts/run-docker.sh

graft assets
graft crates
graft frontend

prune .git
prune .spark
prune .venv
prune dist
prune target
prune tests
prune frontend/artifacts
prune frontend/dist
prune frontend/e2e
prune frontend/node_modules
prune frontend/playwright-report
prune frontend/src/test
prune frontend/test-results
prune frontend/.tmp-*

include tests/compat/providers/test_unified_llm_adapter_fixtures.py
include tests/compat/packaging/test_packaging_smoke_fixtures.py

global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.spec.*
global-exclude *.test.*
global-exclude .DS_Store
